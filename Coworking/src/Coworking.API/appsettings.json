{
  "General": {
    "AutoMigrations": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "ProxySecurity": "Information"
    }
  },
  "ProxySettings": {
    "TrustedProxies": [
    ]
  },
  "MediatR": {
    "Performance": {
      "Enabled": true,
      "ThresholdMs": 10500
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "https://localhost:3000"
  ],

  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Trust Server Certificate=true;Port=5432;Database=coworking;User Id={UID};Password={PWD};"
  },

  "Services": {
    "Smtp": {
      //"MaxConcurrentConnections": 10, // Optional: by default depend of processors count
      "ChannelCapacity": 1000,
      "FromEmail": "yourmail@gmail.com",
      "FromName": "Coworking",
      "Host": "smtp.gmail.com",
      "Password": "app-password",
      "Port": 587,
      "Username": "yourmail@gmail.com",
      "UseSsl": true
    }
  },

  "Squidex": {
    "Apps": {
      "Main": {
        "BaseUrl": "https://fake.cloud.squidex.io",
        "AppName": "my-main-app",
        "MaxPageSize": 200,
        "DefaultClient": "Default",
        "SupportedLocales": [ "uk-UA", "en" ],
        "DefaultLocale": "en",
        "Clients": {
          "Default": {
            "ClientId": "my-app:default",
            "ClientSecret": "secret"
          },
          "Frontend": {
            "ClientId": "my-app:frontend",
            "ClientSecret": "secret"
          }
        }
      },
      "Blog": {
        "BaseUrl": "https://fake.cloud.squidex.io",
        "AppName": "my-blog",
        "DefaultLocale": "en",
        "Clients": {
          "Default": {
            "ClientId": "blog:default",
            "ClientSecret": "secret"
          }
        }
      }
    }
  }
}
